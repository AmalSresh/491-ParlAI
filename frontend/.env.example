# Example environment variables for the frontend.
# Copy to `.env` (do not commit your real `.env` with secrets).

# If your API is served from the same origin, keep "/api".
# If you later move to another host, set this to the full base URL.
VITE_API_BASE_URL="/api"

# Optional: JSON endpoint for the UFC Bets page (see frontend/src/api/ufc/ufcBetsClient.js).
# VITE_UFC_BETS_DATA_URL="https://example.com/ufc/schedule"

